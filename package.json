{
  "name": "demo-credit",
  "version": "1.0.0",
  "description": "MVP wallet service for a mobile lending application",
  "main": "dist/server.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node dist/server.js",
    "migrate": "node --env-file=.env ./node_modules/.bin/knex --knexfile src/database/knexfile.ts migrate:latest",
    "migrate:rollback": "node --env-file=.env ./node_modules/.bin/knex --knexfile src/database/knexfile.ts migrate:rollback",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "type-check": "tsc --noEmit",
    "postinstall": "husky"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.20.0",
    "ofetch": "^1.5.1",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/supertest": "^7.2.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
